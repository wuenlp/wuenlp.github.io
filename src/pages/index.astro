---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const [settingsEntries, newsEntries] = await Promise.all([
    getCollection('settings'),
    getCollection('news'),
]);

const site = settingsEntries[0].data;
const latestNews = newsEntries
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .slice(0, 3);

function fmtDate(d: Date) {
    return d.toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' }).toUpperCase();
}
---

<Layout title="Home">
    <!-- Hero Section: full-width text over background image -->
    <section class="relative px-6 md:px-12 py-10 md:py-14 max-w-screen-2xl mx-auto">

        <!-- Background image + gradient -->
        <div class="absolute inset-0 z-0 overflow-hidden rounded-xl">
            {site.heroImageUrl && (
                <img
                    src={site.heroImageUrl}
                    alt="Abstract digital network visualization"
                    class="w-full h-full object-cover opacity-70"
                />
            )}
            <!-- Gradient from left (opaque) fading out on the right to reveal the image, adjusted to keep wide text readable -->
            <div class="absolute inset-0 bg-gradient-to-r from-surface from-40% via-surface/80 via-70% to-transparent"></div>
        </div>

        <!-- Hero text: wide column -->
        <div class="relative z-10 max-w-4xl">
            <div class="flex items-center gap-6 md:gap-8 mb-6">
                <img
                    src={`${import.meta.env.BASE_URL}logo.svg`}
                    alt="WüNLP Logo"
                    class="h-20 sm:h-24 md:h-32 w-auto shrink-0"
                />
                <h1 class="font-headline text-3xl sm:text-4xl md:text-5xl font-bold leading-tight text-on-surface whitespace-nowrap relative -top-[12px]">
                    {site.heroHeadlineLine1} <br/>
                    <span class="text-primary">{site.heroHeadlineLine2}</span>
                </h1>
            </div>
            <!-- Body text is max-w-4xl, readable because the gradient solidifies the left 60-70% -->
            <p class="font-body text-xl text-on-surface-variant leading-relaxed mb-8">
                {site.heroBody}
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
                <a href={`${import.meta.env.BASE_URL}team`} class="bg-primary text-on-primary px-8 py-4 rounded-lg font-label font-semibold shadow-md hover:bg-primary-container transition-colors flex items-center justify-center gap-2">
                    Meet the Team
                    <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                </a>
                <a href={`${import.meta.env.BASE_URL}publications`} class="px-8 py-4 rounded-lg font-label font-semibold text-primary border border-outline-variant hover:bg-surface-container-low transition-colors flex items-center justify-center text-center">
                    Read Latest Papers
                </a>
            </div>
        </div>
    </section>

    <!-- Group photo: serious by default, funny on hover; full-width to match the hero card -->
    <section class="relative mt-10 md:mt-12 pb-10 md:pb-12 max-w-screen-2xl mx-auto">
        <div class="group relative overflow-hidden rounded-xl ambient-shadow aspect-[3/1]">
            <img
                src={`${import.meta.env.BASE_URL}group-serious.jpg`}
                alt="The WüNLP research group"
                class="absolute inset-0 w-full h-full object-cover object-center transition-opacity duration-500 group-hover:opacity-0"
            />
            <img
                src={`${import.meta.env.BASE_URL}group-funny.jpg`}
                alt="The WüNLP research group having fun"
                class="absolute inset-0 w-full h-full object-cover object-center opacity-0 transition-opacity duration-500 group-hover:opacity-100"
            />
        </div>
    </section>

    <!-- Latest News — structure mirrored from Hero to ensure EXACT width match -->
    <section class="relative px-6 md:px-12 py-10 md:py-12 mb-8 max-w-screen-2xl mx-auto">
        <!-- Background strictly matching the hero's absolute bounds -->
        <div class="absolute inset-0 z-0 bg-surface-container-lowest rounded-xl ambient-shadow"></div>
        
        <div class="relative z-10">
            <div class="flex items-center justify-between mb-8">
                <h3 class="font-headline text-xl font-bold">Latest Updates</h3>
                <span class="material-symbols-outlined text-outline">feed</span>
            </div>
            <div class="space-y-6">
                {latestNews.map(item => (
                    <a href={`${import.meta.env.BASE_URL}news#${item.id}`} class="block group cursor-pointer border-l-2 border-surface-container-high pl-4 hover:border-primary transition-colors">
                        <p class="text-secondary font-label text-xs font-bold mb-1">{fmtDate(item.data.date)}</p>
                        <h4 class="font-body font-semibold text-on-surface group-hover:text-primary transition-colors mb-2">{item.data.title}</h4>
                        {item.body?.trim() && (
                            <p class="font-body text-sm text-on-surface-variant leading-relaxed">
                                {item.body.trim().slice(0, 1024)}{item.body.trim().length > 1024 ? '…' : ''}
                            </p>
                        )}
                    </a>
                ))}
            </div>
            <div class="mt-8 pt-6 border-t border-surface-container-high text-right">
                <a href={`${import.meta.env.BASE_URL}news`} class="text-sm font-label font-medium text-primary hover:underline underline-offset-4 flex items-center gap-1 justify-end">
                    View All News <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                </a>
            </div>
        </div>
    </section>
</Layout>
