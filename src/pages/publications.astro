---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPublications = await getCollection('publications');
const sortedPublications = allPublications.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Publications">
    <!-- Main Content Canvas -->
    <div class="px-6 md:px-12 max-w-screen-xl mx-auto w-full">
        
        <!-- Header Section -->
        <header class="mb-16">
            <h1 class="text-[3.5rem] leading-tight font-headline text-on-surface mb-4">Publications</h1>
            <p class="text-xl font-body text-on-surface-variant max-w-3xl">A chronological archive of our research contributions in Natural Language Processing, Computational Linguistics, and Machine Learning.</p>
        </header>

        <!-- Filter Area -->
        <section class="mb-12 bg-surface-container-low rounded-xl p-6">
            <div class="flex flex-col md:flex-row gap-6 items-center justify-between">
                <div class="flex items-center space-x-4 w-full md:w-auto">
                    <label class="font-label text-sm uppercase tracking-wider text-outline">Filter by Year</label>
                    <div class="flex space-x-2" id="year-filters">
                        <button class="year-btn bg-primary text-on-primary font-body text-sm px-4 py-2 rounded-full shadow-[0_4px_24px_rgba(9,29,46,0.04)] transition-colors" data-year="all">All</button>
                        {[...new Set(sortedPublications.map(p => p.data.date.getFullYear()))].sort((a,b)=>b-a).map(year => (
                            <button class="year-btn bg-surface-container-lowest text-on-surface font-body text-sm px-4 py-2 rounded-full shadow-[0_4px_24px_rgba(9,29,46,0.04)] hover:bg-primary-container hover:text-on-primary-container hover:border-primary transition-colors" data-year={year}>{year}</button>
                        ))}
                    </div>
                </div>
                <div class="w-full md:w-64 relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline-variant">search</span>
                    <input type="text" id="search-input" placeholder="Search by topic or author..." class="w-full bg-surface-container-lowest border-0 border-b-2 border-outline-variant focus:border-primary focus:ring-0 pl-10 pr-4 py-2 font-body text-sm bg-transparent transition-colors" />
                </div>
            </div>
        </section>

        <!-- Publications List -->
        <section class="space-y-8" id="publications-list">
            {sortedPublications.map(pub => (
                <article class="pub-card p-8 bg-surface-container-low rounded-xl hover:bg-surface-container-highest transition-all duration-300 group" data-year={pub.data.date.getFullYear()} data-search={pub.data.title.toLowerCase() + " " + pub.data.authors.toLowerCase()}>
                    <div class="flex flex-col md:flex-row gap-6 items-start">
                        <div class="w-full md:w-48 shrink-0">
                            <span class="inline-block font-label text-sm uppercase tracking-wider text-secondary bg-secondary-container/30 px-3 py-1 rounded-full mb-2">{pub.data.venue}</span>
                            <div class="font-label text-sm text-outline">
                                {pub.data.date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
                            </div>
                        </div>
                        
                        <div class="flex-grow">
                            <h2 class="text-2xl font-headline font-semibold text-on-surface mb-3 group-hover:text-primary transition-colors">
                                {pub.data.title}
                            </h2>
                            <p class="font-body text-on-surface-variant mb-4">{pub.data.authors}</p>
                            
                            <div class="flex flex-wrap gap-4 mt-2">
                                {pub.data.pdfUrl && (
                                    <a href={pub.data.pdfUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-primary font-body text-sm font-medium hover:bg-primary-container hover:text-on-primary-container hover:border-primary transition-all bg-surface-container-lowest px-3 py-1.5 rounded-md border border-outline-variant shadow-sm hover:shadow">
                                        <span class="material-symbols-outlined text-[18px] mr-1.5">picture_as_pdf</span> Get PDF
                                    </a>
                                )}
                            </div>
                        </div>
                    </div>
                </article>
            ))}
        </section>

        <div id="no-results" class="hidden text-center py-12 text-on-surface-variant font-body">
            No publications found matching your search criteria.
        </div>

        <!-- Pagination (Simple) -->
        <div class="mt-12 flex justify-center hidden">
            <button class="text-primary font-body font-semibold px-6 py-2 rounded-lg border border-outline-variant hover:bg-primary-container hover:text-on-primary-container hover:border-primary transition-colors">Load More</button>
        </div>
    </div>
</Layout>

<script>
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const yearBtns = document.querySelectorAll('.year-btn');
    const pubCards = document.querySelectorAll('.pub-card');
    const noResults = document.getElementById('no-results');
    
    let currentYear = 'all';
    let searchQuery = '';

    function filterPublications() {
        let visibleCount = 0;
        
        pubCards.forEach((card) => {
            const htmlCard = card as HTMLElement;
            const cardYear = htmlCard.getAttribute('data-year');
            const cardSearch = htmlCard.getAttribute('data-search') || '';
            
            const matchYear = currentYear === 'all' || cardYear === currentYear;
            const matchSearch = cardSearch.includes(searchQuery);
            
            if (matchYear && matchSearch) {
                htmlCard.classList.remove('hidden');
                visibleCount++;
            } else {
                htmlCard.classList.add('hidden');
            }
        });

        if (noResults) {
            if (visibleCount === 0) {
                noResults.classList.remove('hidden');
            } else {
                noResults.classList.add('hidden');
            }
        }
    }

    if (searchInput) {
        searchInput.addEventListener('input', (e) => {
            searchQuery = (e.target as HTMLInputElement).value.toLowerCase();
            filterPublications();
        });
    }

    yearBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
            const target = e.target as HTMLElement;
            currentYear = target.getAttribute('data-year') || 'all';
            
            // Update active state
            yearBtns.forEach(b => {
                b.classList.remove('bg-primary', 'text-on-primary');
                b.classList.add('bg-surface-container-lowest', 'text-on-surface');
            });
            target.classList.remove('bg-surface-container-lowest', 'text-on-surface');
            target.classList.add('bg-primary', 'text-on-primary');
            
            filterPublications();
        });
    });
</script>
