---
import Layout from '../layouts/Layout.astro';
import TeamMemberCard from '../components/TeamMemberCard.astro';
import { getCollection } from 'astro:content';

const allTeam = await getCollection('team');
type Member = typeof allTeam[number];

// Order within a section: by group rank first, then the per-member `order`, then name.
const groupRank: Record<string, number> = { pi: 0, postdoc: 1, phd: 2, master: 3, student: 4, admin: 5 };
const byRankThenOrder = (a: Member, b: Member) =>
    (groupRank[a.data.group] - groupRank[b.data.group]) ||
    (a.data.order - b.data.order) ||
    a.data.name.localeCompare(b.data.name);

const researchers = allTeam.filter(m => ['pi', 'postdoc', 'phd'].includes(m.data.group)).sort(byRankThenOrder);
const students = allTeam.filter(m => ['master', 'student'].includes(m.data.group)).sort(byRankThenOrder);
const admins = allTeam.filter(m => m.data.group === 'admin').sort(byRankThenOrder);
---

<Layout title="Team">
    <div class="px-6 md:px-12 max-w-screen-2xl mx-auto w-full">
        <!-- Header -->
        <header class="mb-16 md:mb-24 max-w-4xl">
            <span class="font-label text-sm font-semibold tracking-widest uppercase text-tertiary-container mb-4 block">The People</span>
            <h1 class="font-headline text-5xl md:text-7xl font-bold text-primary leading-tight">Our Team</h1>
        </header>

        <!-- Researchers -->
        <section class="mb-20">
            <h2 class="font-headline text-3xl font-bold text-on-surface mb-10 border-l-4 border-primary pl-4">Researchers</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
                {researchers.map(member => <TeamMemberCard member={member} />)}
            </div>
        </section>

        <!-- Students -->
        <section class="mb-20">
            <h2 class="font-headline text-3xl font-bold text-on-surface mb-10 border-l-4 border-secondary pl-4">Students</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
                {students.map(member => <TeamMemberCard member={member} />)}
            </div>
        </section>

        <!-- Administration -->
        <section class="mb-20">
            <h2 class="font-headline text-3xl font-bold text-on-surface mb-10 border-l-4 border-tertiary pl-4">Administration</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
                {admins.map(member => <TeamMemberCard member={member} />)}
            </div>
        </section>

        <!-- Join Us CTA -->
        <section class="mb-20">
            <div class="bg-inverse-surface text-inverse-on-surface rounded-xl p-10 md:p-16 flex flex-col md:flex-row gap-10 items-center justify-between">
                <div class="w-full">
                    <h2 class="font-headline text-3xl md:text-4xl font-bold mb-4 text-inverse-primary">
                        Interested in Joining Us?
                    </h2>
                    <p class="font-body text-lg opacity-90 leading-relaxed">
                        You really like what we do and would want to be part of the team? We may have some open positions right now. Or we may have them in the near future. In any case, if you're interested, <a href={`${import.meta.env.BASE_URL}contact`} class="font-semibold underline underline-offset-4 text-inverse-primary hover:opacity-80 transition-opacity">drop us a line</a>. Make sure to include a short statement of interest and a CV.
                    </p>
                </div>
            </div>
        </section>
    </div>
</Layout>
