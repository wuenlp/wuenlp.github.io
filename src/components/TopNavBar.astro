---
const { currentPath } = Astro.props;

const navItems = [
    { label: 'Home', href: import.meta.env.BASE_URL },
    { label: 'Team', href: `${import.meta.env.BASE_URL}team` },
    { label: 'Publications', href: `${import.meta.env.BASE_URL}publications` },
    { label: 'Teaching', href: `${import.meta.env.BASE_URL}teaching` },
    { label: 'News', href: `${import.meta.env.BASE_URL}news` },
];
---
<nav class="fixed top-0 w-full z-50 bg-surface/80 backdrop-blur-md shadow-sm bg-opacity-90">
    <div class="flex justify-between items-center px-12 py-6 max-w-screen-2xl mx-auto">
        <div class="hidden md:flex space-x-8 items-center">
            {navItems.map(item => (
                <a 
                    href={item.href} 
                    class={`font-headline tracking-tight font-bold text-lg transition-colors px-3 py-2 rounded-md hover:bg-slate-100/50 ${
                        currentPath === item.href 
                        ? 'text-sky-700 border-b-2 border-sky-700 pb-1' 
                        : 'text-slate-600 hover:text-sky-600'
                    }`}
                >
                    {item.label}
                </a>
            ))}
        </div>
        <div class="flex items-center space-x-4">
            <a href={`${import.meta.env.BASE_URL}contact`} class="hidden md:inline-flex bg-primary text-on-primary font-body font-semibold px-6 py-2.5 rounded-lg bg-gradient-to-br from-primary to-primary-container hover:shadow-md transition-shadow">
                Contact
            </a>
            <button id="mobile-menu-btn" class="md:hidden text-sky-700 p-2 hover:bg-slate-100/50 rounded-md transition-all scale-95">
                <span class="material-symbols-outlined">menu</span>
            </button>
        </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 w-full bg-surface shadow-md border-t border-slate-100 p-4 flex-col space-y-3">
        {navItems.map(item => (
            <a 
                href={item.href} 
                class={`block font-headline font-bold text-lg px-4 py-2 rounded-md ${
                    currentPath === item.href 
                    ? 'text-sky-700 bg-sky-50' 
                    : 'text-slate-600 hover:bg-slate-50'
                }`}
            >
                {item.label}
            </a>
        ))}
        <a href={`${import.meta.env.BASE_URL}contact`} class="block text-center mt-4 bg-primary text-on-primary font-body font-semibold px-6 py-3 rounded-lg bg-gradient-to-br from-primary to-primary-container shadow-sm">
            Contact Us
        </a>
    </div>
</nav>

<script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    
    if (btn && menu) {
        btn.addEventListener('click', () => {
            menu.classList.toggle('hidden');
            menu.classList.toggle('flex');
        });
    }
</script>
