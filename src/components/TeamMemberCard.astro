---
// Large photo card for a single team member (shared across all Team sections).
// Shows the cartoon by default; if both exist, the real photo cross-fades in on hover.
const { member } = Astro.props;
const m = member.data;
const base = m.cartoon || m.photo;            // shown by default
const hover = m.cartoon && m.photo ? m.photo : null; // shown on hover (only when we can swap)
---
<div class="group relative bg-surface-container-low rounded-xl overflow-hidden transition-all duration-300 hover:bg-surface-container-high">
    {base && (
        <div class="relative aspect-[3/4]">
            <img
                src={base}
                alt={m.name}
                class:list={["absolute inset-0 object-cover w-full h-full transition-opacity duration-500", hover && "group-hover:opacity-0"]}
            />
            {hover && (
                <img
                    src={hover}
                    alt={`${m.name} (photo)`}
                    class="absolute inset-0 object-cover w-full h-full opacity-0 transition-opacity duration-500 group-hover:opacity-100"
                />
            )}
            <div class="absolute bottom-0 left-0 w-full p-6 bg-gradient-to-t from-black/80 to-transparent pointer-events-none">
                <div class="bg-surface-container-lowest/90 glass-panel p-4 rounded-lg inline-block transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                    <h3 class="font-headline text-2xl font-bold text-on-surface mb-1">{m.name}</h3>
                    <p class="font-label text-sm text-primary font-medium">{m.role}</p>
                </div>
            </div>
        </div>
    )}
    <div class="p-6 pt-8">
        {!base && (
            <div class="mb-4">
                <h3 class="font-headline text-2xl font-bold text-on-surface mb-1">{m.name}</h3>
                <p class="font-label text-sm text-primary font-medium">{m.role}</p>
            </div>
        )}
        {m.researchFocus && (
            <p class="font-body text-on-surface-variant mb-6 text-sm leading-relaxed">{m.researchFocus}</p>
        )}
        <div class="flex items-center space-x-4">
            {m.linkedinUrl && (
                <a href={m.linkedinUrl} target="_blank" rel="noopener" aria-label={`${m.name} on LinkedIn`} class="text-tertiary hover:text-primary transition-colors flex items-center space-x-1 text-sm font-medium">
                    <svg viewBox="0 0 24 24" class="w-[18px] h-[18px] fill-current" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    <span>LinkedIn</span>
                </a>
            )}
            {m.scholarUrl && (
                <a href={m.scholarUrl} target="_blank" rel="noopener" aria-label={`${m.name} on Google Scholar`} class="text-tertiary hover:text-primary transition-colors flex items-center space-x-1 text-sm font-medium">
                    <svg viewBox="0 0 24 24" class="w-[18px] h-[18px] fill-current" aria-hidden="true"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/></svg>
                    <span>Scholar</span>
                </a>
            )}
        </div>
    </div>
</div>
